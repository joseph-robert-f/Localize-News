# Copy this to .env.local and fill in real values.
# Never commit .env.local.

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App secrets ──────────────────────────────────────────────────────────────
# Shared secret for admin-only routes (/admin, /api/scrape)
ADMIN_SECRET=change-me-to-a-long-random-string

# Secret sent in x-cron-secret header by pg_cron job
# Also set as DB setting: ALTER DATABASE postgres SET app.cron_secret = '...';
CRON_SECRET=change-me-to-another-long-random-string
