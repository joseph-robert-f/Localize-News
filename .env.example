# Copy this to .env.local and fill in real values.
# Never commit .env.local.

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI summaries ─────────────────────────────────────────────────────────────
# Anthropic API key — used to generate 2-3 sentence document summaries
# Get one at: https://console.anthropic.com
# If unset, documents are still scraped and indexed; summaries just won't appear
ANTHROPIC_API_KEY=

# ── Search ───────────────────────────────────────────────────────────────────
# Brave Search API key — free tier: 2,000 queries/month
# Get one at: https://api.search.brave.com/app/
# If unset, scraper falls back to DuckDuckGo HTML scrape (fragile, dev-only)
BRAVE_SEARCH_API_KEY=

# ── AI summaries ─────────────────────────────────────────────────────────────
# Claude API key for AI-generated document summaries (server-only)
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── App secrets ──────────────────────────────────────────────────────────────
# Shared secret for admin-only routes (/admin, /api/scrape)
ADMIN_SECRET=change-me-to-a-long-random-string

# Secret sent in x-cron-secret header by pg_cron job
# Also set as DB setting: ALTER DATABASE postgres SET app.cron_secret = '...';
CRON_SECRET=change-me-to-another-long-random-string
